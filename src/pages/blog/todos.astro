---
import Layout from '../../layouts/Layout.astro';

// Traemos los posts desde la API (sin límites)
const response = await fetch(import.meta.env.PUBLIC_WP_URL.replace('?_embed', ''));
const posts = await response.json();

const seoTitle = "Todos los artículos | Blog | Diseñarte México";
const seoDescription = "Explora nuestro catálogo completo de artículos sobre diseño, marketing e impresión industrial.";

function extraerPrimeraImagen(content: string): string | null {
  const regex = /<img[^>]+src="([^">]+)"/i;
  const match = regex.exec(content);
  return match ? match[1] : null;
}
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="bg-white pt-32 pb-20 min-h-screen text-[#1a1a1a] font-avenir-book">
    <div class="max-w-7xl mx-auto px-4">
      
      {/* --- ENCABEZADO: TODOS LOS ARTÍCULOS --- */}
      <header class="mb-16 text-left max-w-4xl">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-avenir-book text-gray-900 leading-[1.1] uppercase tracking-tighter">
              Todos los <span class="font-avenir-black text-[#7C07A6]">artículos</span>
          </h1>
          <div class="h-1.5 w-24 bg-[#7C07A6] mt-6 opacity-80 rounded-full"></div>
      </header>

      {/* --- GRID COMPLETO (Sin slice) --- */}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {posts.map((post: any) => {
          const urlPrimeraImagen = extraerPrimeraImagen(post.content.rendered);

          return (
            <article class="group bg-gray-50 rounded-[2.5rem] overflow-hidden border border-gray-100 hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 flex flex-col">
              
              <div class="aspect-[4/3] overflow-hidden bg-gray-200">
                {urlPrimeraImagen ? (
                  <img 
                    src={urlPrimeraImagen} 
                    alt={post.title.rendered}
                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gray-100 text-gray-400 font-bold uppercase tracking-widest text-xs">
                    <span class="text-center px-4 font-avenir-black">Diseñarte <br/> México</span>
                  </div>
                )}
              </div>

              <div class="p-10 flex flex-col flex-grow">
                <span class="text-xs font-black uppercase tracking-widest text-[#7C07A6] mb-4 block">
                  {new Date(post.date).toLocaleDateString('es-MX', { month: 'long', year: 'numeric' })}
                </span>
                
                <h2 
                  class="text-2xl font-black mb-4 leading-tight group-hover:text-[#7C07A6] transition-colors line-clamp-2"
                  set:html={post.title.rendered} 
                />
                
                <div 
                  class="text-gray-500 font-light line-clamp-3 mb-8 text-lg leading-relaxed flex-grow"
                  set:html={post.excerpt.rendered} 
                />

                <a href={`/blog/${post.slug}`} class="inline-flex items-center space-x-3 group/btn mt-auto">
                  <div class="w-10 h-10 rounded-full bg-[#7C07A6] flex items-center justify-center text-white transition-transform group-hover/btn:translate-x-2">
                    <span class="text-xl">→</span>
                  </div>
                  <span class="font-black uppercase text-sm tracking-tighter">Leer artículo</span>
                </a>
              </div>
            </article>
          );
        })}
      </div>

      {/* --- BOTÓN PARA REGRESAR --- */}
      <div class="mt-20 flex justify-center">
        <a href="/blog" class="inline-flex items-center text-sm font-avenir-black uppercase tracking-widest text-gray-400 hover:text-[#7C07A6] transition-colors">
            <span class="mr-2">←</span> Volver a ultimos artículos
        </a>
      </div>

    </div>
  </main>
</Layout>

<style is:global>
    @font-face {
        font-family: 'Avenir Book';
        src: url('/fonts/avenir-lt-std-45-book.otf') format('opentype');
        font-weight: 400; font-style: normal; font-display: swap;
    }
    @font-face {
        font-family: 'Avenir Black';
        src: url('/fonts/avenir-lt-std-65-medium.otf') format('opentype');
        font-weight: 900; font-style: normal; font-display: swap;
    }

    .font-avenir-book { font-family: 'Avenir Book', sans-serif; }
    .font-avenir-black { font-family: 'Avenir Black', sans-serif; font-weight: 900; }
    .group:hover h2 { color: #7C07A6 !important; }
</style>