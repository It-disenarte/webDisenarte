---
/**
 * PÁGINA: TODOS LOS ARTÍCULOS - Diseñarte México
 * Arquitectura: Astro + Tailwind CSS + WordPress API
 */
import Layout from '../../layouts/Layout.astro';

// Traemos los posts desde la API (sin límites de slice)
const response = await fetch(import.meta.env.PUBLIC_WP_URL.replace('?_embed', ''));
const posts = await response.json();

const seoTitle = "Todos los artículos | Blog | Diseñarte México";
const seoDescription = "Explora nuestro catálogo completo de artículos sobre diseño, marketing e impresión industrial.";

// --- FUNCIÓN DE AYUDA: EXTRAER PRIMERA IMAGEN ---
function extraerPrimeraImagen(content: string): string | null {
  const regex = /<img[^>]+src="([^">]+)"/i;
  const match = regex.exec(content);
  return match ? match[1] : null;
}
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="all-posts-container">
    <div class="max-w-7xl mx-auto px-4">
      
      <header class="mb-16 text-left max-w-4xl">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-avenir-book text-gray-900 leading-[1.1] uppercase tracking-tighter">
              Todos los <span class="font-avenir-black text-purple-all">artículos</span>
          </h1>
          <div class="h-1.5 w-24 bg-purple-all mt-6 opacity-80 rounded-full"></div>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {posts.map((post: any) => {
          const urlPrimeraImagen = extraerPrimeraImagen(post.content.rendered);

          return (
            <article class="all-blog-card group">
              
              <div class="all-card-image-wrapper">
                {urlPrimeraImagen ? (
                  <img 
                    src={urlPrimeraImagen} 
                    alt={post.title.rendered}
                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gray-100 text-gray-400">
                    <span class="text-center px-4 font-avenir-black uppercase tracking-widest text-xs">
                      Diseñarte <br/> México
                    </span>
                  </div>
                )}
              </div>

              <div class="p-10 flex flex-col flex-grow">
                <span class="text-xs font-avenir-black uppercase tracking-widest text-purple-all mb-4 block">
                  {new Date(post.date).toLocaleDateString('es-MX', { month: 'long', year: 'numeric' })}
                </span>
                
                <h2 
                  class="text-2xl font-avenir-black mb-4 leading-tight group-hover:text-purple-all transition-colors line-clamp-2 text-gray-900"
                  set:html={post.title.rendered} 
                />
                
                <div 
                  class="text-gray-500 font-avenir-book line-clamp-3 mb-8 text-lg leading-relaxed flex-grow opacity-80"
                  set:html={post.excerpt.rendered} 
                />

                <a href={`/blog/${post.slug}`} class="inline-flex items-center space-x-3 group/btn mt-auto no-underline">
                  <div class="w-10 h-10 rounded-full bg-purple-all flex items-center justify-center text-white transition-transform group-hover/btn:translate-x-2">
                    <span class="text-xl">→</span>
                  </div>
                  <span class="font-avenir-black uppercase text-sm tracking-tighter text-gray-900">Leer artículo</span>
                </a>
              </div>
            </article>
          );
        })}
      </div>

      <footer class="mt-20 flex justify-center">
        <a href="/blog" class="back-blog-btn group">
            <span class="text-xl transition-transform group-hover:-translate-x-2">←</span>
            <span class="font-avenir-black uppercase text-sm tracking-widest">Volver</span>
        </a>
      </footer>

    </div>
  </main>
</Layout>

<style is:global>
    /** 1. TIPOGRAFÍA **/
    @font-face {
        font-family: 'Avenir Book';
        src: url('/fonts/avenir-lt-std-45-book.otf') format('opentype');
        font-weight: 400; font-style: normal; font-display: swap;
    }
    @font-face {
        font-family: 'Avenir Black';
        src: url('/fonts/avenir-lt-std-65-medium.otf') format('opentype');
        font-weight: 900; font-style: normal; font-display: swap;
    }

    :root {
        --purple-all: #7C07A6;
    }

    .font-avenir-book { font-family: 'Avenir Book', sans-serif; }
    .font-avenir-black { font-family: 'Avenir Black', sans-serif; font-weight: 900; }
    .text-purple-all { color: var(--purple-all); }
    .bg-purple-all { background-color: var(--purple-all); }

    .all-posts-container {
        background-color: #ffffff;
        padding-top: 8rem;
        padding-bottom: 5rem;
        min-height: 100vh;
        font-family: 'Avenir Book', sans-serif;
    }

    /** 2. TARJETAS **/
    .all-blog-card {
        background-color: #f9fafb;
        border-radius: 2.5rem;
        overflow: hidden;
        border: 1px solid #f3f4f6;
        transition: all 0.5s ease;
        display: flex;
        flex-direction: column;
    }
    .all-blog-card:hover {
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        transform: translateY(-0.75rem);
    }

    .all-card-image-wrapper {
        aspect-ratio: 4 / 3;
        overflow: hidden;
        background-color: #e5e7eb;
    }

    /** 3. BOTÓN REGRESAR (ESTILO UNIFICADO) **/
    .back-blog-btn {
        display: flex;
        align-items: center;
        gap: 1rem;
        background-color: #f9fafb;
        padding: 1.25rem 2.5rem;
        border-radius: 9999px;
        transition: all 0.5s ease;
        text-decoration: none;
        color: #1a1a1a;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    .back-blog-btn:hover {
        background-color: var(--purple-all);
        color: #ffffff;
        box-shadow: 0 10px 15px -3px rgba(124, 7, 166, 0.3);
    }

    /* Helpers */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>