---
// @ts-nocheck
import Layout from '../../layouts/Layout.astro';

/**
 * 1. GENERACIÓN ESTÁTICA (SSG) PARA CPANEL
 * Esta función descarga los posts de WordPress y crea las rutas.
 */
export async function getStaticPaths() {
  const wpUrl = import.meta.env.PUBLIC_WP_URL;
  const baseUrl = wpUrl.split('?')[0]; 
  
  const response = await fetch(`${baseUrl}?_embed&per_page=100`);
  const posts = await response.json();

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// 2. Recibimos los datos del post
const { post } = Astro.props;

// 3. SEO y Limpieza de texto para la descripción
const seoTitle = `${post.title.rendered} | Blog Diseñarte México`;
const seoDescription = post.excerpt.rendered
  ? post.excerpt.rendered.replace(/<[^>]*>?/gm, '').substring(0, 160)
  : "Lee nuestro último artículo en el blog de Diseñarte México";
---

<Layout title={seoTitle} description={seoDescription}>
  <article class="bg-white min-h-screen pt-40 pb-24 overflow-hidden font-avenir-book text-[#1a1a1a]">
    
    <div class="max-w-4xl mx-auto px-6">
      
      <header class="mb-16 text-center">
        <div class="inline-block px-5 py-2 rounded-full bg-[#f4f4f6] text-[#7C07A6] text-xs font-avenir-black uppercase tracking-widest mb-6">
            {new Date(post.date).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' })}
        </div>
        
        <h1 
            class="text-4xl md:text-6xl font-avenir-black leading-[1.1] mb-8 text-[#1a1a1a] uppercase tracking-tighter" 
            set:html={post.title.rendered} 
        />
        
        <div class="h-1.5 w-24 bg-[#7C07A6] mx-auto opacity-80 rounded-full"></div>
      </header>

      {/* Imagen Destacada */}
      {post._embedded && post._embedded['wp:featuredmedia'] && (
        <div class="mb-16 rounded-[2.5rem] overflow-hidden shadow-2xl transform -rotate-1 border border-gray-100">
          <img 
            src={post._embedded['wp:featuredmedia'][0].source_url} 
            alt={post.title.rendered}
            class="w-full h-auto object-cover"
          />
        </div>
      )}

      {/* Cuerpo del artículo */}
      <div class="content-body prose prose-xl max-w-none leading-relaxed text-gray-700">
        <div set:html={post.content.rendered} />
      </div>

      <footer class="mt-20 pt-10 border-t border-gray-100 flex justify-center">
        <a href="/blog" class="group flex items-center space-x-4 bg-gray-50 hover:bg-[#7C07A6] hover:text-white px-10 py-5 rounded-full transition-all duration-500 shadow-sm hover:shadow-xl">
            <span class="text-xl group-hover:-translate-x-2 transition-transform">←</span>
            <span class="font-avenir-black uppercase text-sm tracking-widest">Volver al Blog</span>
        </a>
      </footer>

    </div>
  </article>
</Layout>

<style is:global>
  @font-face {
    font-family: 'Avenir Book';
    src: url('/fonts/avenir-lt-std-45-book.otf') format('opentype');
    font-weight: 400; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: 'Avenir Black';
    src: url('/fonts/avenir-lt-std-65-medium.otf') format('opentype');
    font-weight: 900; font-style: normal; font-display: swap;
  }

  .font-avenir-book { font-family: 'Avenir Book', sans-serif; }
  .font-avenir-black { font-family: 'Avenir Black', sans-serif; font-weight: 900; }

  /* Estilizado del contenido de WordPress */
  .content-body p { margin-bottom: 2rem; font-size: 1.2rem; line-height: 1.8; }
  .content-body h2 { font-family: 'Avenir Black', sans-serif; font-size: 2.5rem; margin-top: 4rem; margin-bottom: 1.5rem; color: #1a1a1a; line-height: 1.1; text-transform: uppercase; letter-spacing: -0.05em; }
  .content-body h3 { font-family: 'Avenir Black', sans-serif; font-size: 1.8rem; margin-top: 3rem; color: #7C07A6; }
  .content-body img { border-radius: 2rem; margin: 3.5rem auto; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15); }
  .content-body ul { list-style: none; padding-left: 1rem; margin-bottom: 2.5rem; }
  .content-body li { position: relative; margin-bottom: 1.2rem; padding-left: 2rem; font-size: 1.15rem; }
  .content-body li::before { content: ""; width: 8px; height: 8px; background-color: #7C07A6; border-radius: 50%; position: absolute; left: 0; top: 10px; }
  .content-body blockquote { border-left: 8px solid #7C07A6; padding: 2.5rem; background: #fdfaff; font-style: italic; font-weight: 500; border-radius: 0 2.5rem 2.5rem 0; margin: 4rem 0; font-size: 1.4rem; color: #4a4a4a; }
</style>