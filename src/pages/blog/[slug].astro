---
// @ts-nocheck
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

/**
 * 1. GENERACIÓN ESTÁTICA (SSG)
 */
export async function getStaticPaths() {
  const wpUrl = import.meta.env.PUBLIC_WP_URL;
  const baseUrl = wpUrl.split('?')[0]; 
  
  const response = await fetch(`${baseUrl}?_embed&per_page=100`);
  const posts = await response.json();

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

// 3. SEO y Limpieza de texto (Mejorada para evitar caracteres raros de WP)
const seoTitle = `${post.title.rendered} | Blog Diseñarte México`;
const seoDescription = post.excerpt.rendered
  ? post.excerpt.rendered
      .replace(/<[^>]*>?/gm, '') // Quita HTML
      .replace(/&nbsp;/g, ' ')   // Quita espacios de WP
      .replace(/\s+/g, ' ')      // Quita saltos de línea
      .trim()
      .substring(0, 160)
  : "Lee nuestro último artículo en el blog de Diseñarte México";

const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.source_url;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<Layout title={seoTitle} description={seoDescription} image={featuredImage}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.title.rendered,
    "description": seoDescription,
    "image": featuredImage,
    "datePublished": post.date,
    "author": {"@type": "Organization", "name": "Diseñarte México"}
  })} />

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.disenartemx.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://www.disenartemx.com/blog" },
      { "@type": "ListItem", "position": 3, "name": post.title.rendered, "item": canonicalURL }
    ]
  })} />

  <article class="post-article-container">
    <div class="max-w-4xl mx-auto px-6">
      
      <header class="mb-16 text-center">
        <div class="post-date-badge">
            {new Date(post.date).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' })}
        </div>
        
        <h1 
            class="text-4xl md:text-6xl font-avenir-black leading-[1.1] mb-8 text-gray-900 uppercase tracking-tighter" 
            set:html={post.title.rendered} 
        />
        
        <div class="h-1.5 w-24 bg-purple-post mx-auto opacity-80 rounded-full"></div>
      </header>

      {post._embedded && post._embedded['wp:featuredmedia'] && (
        <div class="featured-image-wrapper">
          <Image 
            src={post._embedded['wp:featuredmedia'][0].source_url} 
            alt={post.title.rendered}
            width={1200}
            height={630}
            format="webp"
            class="w-full h-auto object-cover"
          />
        </div>
      )}

      <div class="content-body">
        <div set:html={post.content.rendered} />
      </div>

      <footer class="mt-20 pt-10 border-t border-gray-100 flex justify-center">
        <a href="/blog" class="back-blog-btn group">
            <span class="text-xl transition-transform group-hover:-translate-x-2">←</span>
            <span class="font-avenir-black uppercase text-sm tracking-widest">Volver</span>
        </a>
      </footer>

    </div>
  </article>
</Layout>

<style is:global>
  @font-face {
    font-family: 'Avenir Book';
    src: url('/fonts/avenir-lt-std-45-book.otf') format('opentype');
    font-weight: 400; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: 'Avenir Black';
    src: url('/fonts/avenir-lt-std-65-medium.otf') format('opentype');
    font-weight: 900; font-style: normal; font-display: swap;
  }

  :root {
      --purple-post: #7C07A6;
  }

  .font-avenir-book { font-family: 'Avenir Book', sans-serif; }
  .font-avenir-black { font-family: 'Avenir Black', sans-serif; font-weight: 900; }
  .bg-purple-post { background-color: var(--purple-post); }

  .post-article-container {
      background-color: #ffffff;
      min-height: 100vh;
      padding-top: 10rem;
      padding-bottom: 6rem;
      font-family: 'Avenir Book', sans-serif;
  }

  .post-date-badge {
      display: inline-block;
      padding: 0.5rem 1.25rem;
      border-radius: 9999px;
      background-color: #f4f4f6;
      color: var(--purple-post);
      font-family: 'Avenir Black', sans-serif;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 1.5rem;
  }

  .featured-image-wrapper {
      margin-bottom: 4rem;
      border-radius: 2.5rem;
      overflow: hidden;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
      border: 1px solid #f3f4f6;
      transform: rotate(-1deg);
  }

  .back-blog-btn {
      display: flex;
      align-items: center;
      gap: 1rem;
      background-color: #f9fafb;
      padding: 1.25rem 2.5rem;
      border-radius: 9999px;
      transition: all 0.5s ease;
      text-decoration: none;
      color: #1a1a1a;
  }

  .back-blog-btn:hover {
      background-color: var(--purple-post);
      color: #ffffff;
      box-shadow: 0 10px 15px -3px rgba(124, 7, 166, 0.3);
  }

  .content-body {
      color: #374151;
      font-size: 1.125rem;
      line-height: 1.8;
  }

  .content-body p { 
      margin-bottom: 2rem; 
      font-size: 1.2rem; 
  }

  .content-body h2 { 
      font-family: 'Avenir Black', sans-serif; 
      font-size: 2.5rem; 
      margin-top: 4rem; 
      margin-bottom: 1.5rem; 
      color: #1a1a1a; 
      line-height: 1.1; 
      text-transform: uppercase; 
      letter-spacing: -0.05em; 
  }

  .content-body h3 { 
      font-family: 'Avenir Black', sans-serif; 
      font-size: 1.8rem; 
      margin-top: 3rem; 
      color: var(--purple-post); 
  }

  .content-body img { 
      border-radius: 2rem; 
      margin: 3.5rem auto; 
      box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15); 
  }

  .content-body ul { 
      list-style: none; 
      padding-left: 1rem; 
      margin-bottom: 2.5rem; 
  }

  .content-body li { 
      position: relative; 
      margin-bottom: 1.2rem; 
      padding-left: 2rem; 
      font-size: 1.15rem; 
  }

  .content-body li::before { 
      content: ""; 
      width: 8px; 
      height: 8px; 
      background-color: var(--purple-post); 
      border-radius: 50%; 
      position: absolute; 
      left: 0; 
      top: 10px; 
  }

  .content-body blockquote { 
      border-left: 8px solid var(--purple-post); 
      padding: 2.5rem; 
      background: #fdfaff; 
      font-style: italic; 
      font-weight: 500; 
      border-radius: 0 2.5rem 2.5rem 0; 
      margin: 4rem 0; 
      font-size: 1.4rem; 
      color: #4a4a4a; 
  }
</style>