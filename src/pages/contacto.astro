---
/**
 * PÁGINA: CONTACTO - Diseñarte México
 * Arquitectura: Astro + Tailwind CSS
 * Solución: Detección dinámica de origen para evitar errores de CORS.
 */
import Layout from "../layouts/Layout.astro";

const seoTitle = "Agenda una sesión | Contacto | Diseñarte México";
const seoDescription = "Reserva una cita con nuestros agentes de ventas para tus proyectos de publicidad y marketing digital en San Juan del Río.";
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="bg-[#f4f4f4] min-h-screen pt-16 md:pt-24 lg:pt-32 pb-16 font-avenir-book overflow-x-hidden relative">
    
    <div class="max-w-[1550px] mx-auto px-4 md:px-8 lg:px-12">
      
      <header class="mb-10 md:mb-16 flex flex-col items-start max-w-5xl">
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-avenir-book tracking-tighter uppercase leading-[1.1] mb-6 text-gray-900">
          ¡<span class="font-avenir-black text-purple-accent">Agenda una sesión</span> con uno de nuestros agentes de ventas <span class="font-avenir-black text-purple-accent">para revisar tu proyecto!</span>
        </h1>
        <div class="h-1.5 w-24 bg-purple-accent opacity-70 rounded-full"></div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 xl:gap-16 items-start">
        
        <section class="lg:col-span-5 bg-[#e2e4e6] p-7 md:p-10 lg:p-12 rounded-[2rem] md:rounded-[2.5rem] shadow-2xl border border-gray-200 relative z-20">
          <h2 class="sr-only">Formulario de contacto</h2>
          
          <form id="contact-form" class="space-y-6">
            <div class="space-y-2">
              <label for="nombre" class="form-label">Nombre completo*</label>
              <input type="text" id="nombre" name="nombre" required class="form-input" placeholder="Ej. Juan Pérez" />
            </div>

            <div class="space-y-2">
              <label for="telefono" class="form-label">Teléfono*</label>
              <input type="tel" id="telefono" name="telefono" required class="form-input" placeholder="427 000 0000" />
            </div>

            <div class="space-y-2">
              <label for="correo" class="form-label">Correo Electrónico*</label>
              <input type="email" id="correo" name="correo" required class="form-input" placeholder="correo@ejemplo.com" />
            </div>

            <div class="space-y-2">
                <label for="empresa" class="form-label">Empresa (Opcional)</label>
                <input type="text" id="empresa" name="empresa" class="form-input" placeholder="Nombre de tu negocio" />
            </div>

            <div class="space-y-2">
              <label for="mensaje" class="form-label">Mensaje*</label>
              <textarea id="mensaje" name="mensaje" rows="4" required class="form-input rounded-[2rem] resize-none" placeholder="Cuéntanos sobre tu proyecto..."></textarea>
            </div>

            <div class="pt-4">
              <button type="submit" id="submit-btn" class="btn-submit">
                <span id="btn-text">ENVIAR SOLICITUD</span>
              </button>
            </div>
          </form>
        </section>

        <aside class="lg:col-span-7 space-y-24 lg:space-y-12 relative z-10 lg:pl-20">
          
          <article class="location-card group">
            <div class="map-container">
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3741.010101010101!2d-99.99!3d20.38!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjDCsDIyJzQ4LjAiTiA5OcKwNTknMjQuMCJX!5e0!3m2!1ses-419!2smx!4v1700000000000" 
                    title="Ubicación Diseñarte México Publicidad" 
                    class="w-full h-full grayscale group-hover:grayscale-0 transition-all duration-700 border-0" 
                    allowfullscreen="" 
                    loading="lazy">
                </iframe>
            </div>
            <div class="contact-info-block">
              <h3 class="text-xl md:text-2xl font-avenir-black uppercase mb-4 text-white">Publicidad</h3>
              <ul class="space-y-2 text-xs md:text-sm font-avenir-book mb-4 text-white/90">
                <li class="flex items-center justify-center gap-2"><span>📞</span> 427 211 05 28</li>
                <li class="flex items-center justify-center gap-2"><span>✉️</span> ventas@disenartemx.com</li>
              </ul>
              <p class="pt-3 border-t border-white/20 px-3 text-[10px] md:text-xs text-white/80 leading-snug">
                Av. Lomas del pedregoso #371.<br/>Col. Lomas de San Juan.
              </p>
            </div>
          </article>

          <article class="location-card group">
            <div class="map-container">
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3741.010101010101!2d-99.98!3d20.37!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjDCsDIyJzQ4LjAiTiA5OcKwNTknMjQuMCJX!5e0!3m2!1ses-419!2smx!4v1700000000000" 
                    title="Ubicación Diseñarte México Marketing" 
                    class="w-full h-full grayscale group-hover:grayscale-0 transition-all duration-700 border-0" 
                    allowfullscreen="" 
                    loading="lazy">
                </iframe>
            </div>
            <div class="contact-info-block">
              <h3 class="text-xl md:text-2xl font-avenir-black uppercase mb-4 text-white">Marketing Digital</h3>
              <ul class="space-y-2 text-xs md:text-sm font-avenir-book mb-4 text-white/90">
                <li class="flex items-center justify-center gap-2"><span>💬</span> 427 345 91 83</li>
                <li class="flex items-center justify-center gap-2"><span>✉️</span> marketing@disenarte-mexico.org</li>
              </ul>
              <p class="pt-3 border-t border-white/20 px-3 text-[10px] md:text-xs text-white/80 leading-snug">
                Av. Mármol #5.<br/>Col. El Pedregal.
              </p>
            </div>
          </article>

        </aside>

      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  // Detectamos el dominio actual dinámicamente para evitar el error de CORS
  const PHP_ACTION_URL = `${window.location.origin}/procesar.php`;

  const form = document.getElementById('contact-form');
  const btn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Estado de carga
    btn.disabled = true;
    btn.style.opacity = "0.7";
    btnText.innerText = "ENVIANDO SOLICITUD...";

    const formData = new FormData(form);

    try {
      const response = await fetch(PHP_ACTION_URL, {
        method: 'POST',
        mode: 'cors', // Asegura el intercambio de recursos entre orígenes si es necesario
        body: formData,
      });

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      const result = await response.json();

      if (result.status === 'success') {
        alert("¡Mensaje enviado con éxito! Nos pondremos en contacto pronto.");
        form.reset();
      } else {
        alert("Atención: " + result.message);
      }
    } catch (error) {
      console.error("Error en el envío:", error);
      alert("Hubo un error de conexión con el servidor. Por favor, intenta de nuevo o contáctanos por WhatsApp.");
    } finally {
      // Restaurar botón
      btn.disabled = false;
      btn.style.opacity = "1";
      btnText.innerText = "ENVIAR SOLICITUD";
    }
  });
</script>

<style is:global>
  @font-face {
    font-family: 'Avenir Book';
    src: url('/fonts/avenir-lt-std-45-book.otf') format('opentype');
    font-weight: 400; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: 'Avenir Black';
    src: url('/fonts/avenir-lt-std-65-medium.otf') format('opentype');
    font-weight: 900; font-style: normal; font-display: swap;
  }

  :root {
      --purple-accent: #712c91;
      --cyan-label: #66bcc9;
  }

  .font-avenir-book { font-family: 'Avenir Book', sans-serif; }
  .font-avenir-black { font-family: 'Avenir Black', sans-serif; font-weight: 900; }
  .text-purple-accent { color: #712c91; }
  .bg-purple-accent { background-color: #712c91; }

  .form-label {
      display: block;
      font-size: 0.875rem;
      font-family: 'Avenir Black', sans-serif;
      text-transform: uppercase;
      color: #66bcc9;
  }

  .form-input {
      width: 100%;
      padding: 0.75rem 1.25rem;
      border-radius: 0.75rem;
      background-color: #ffffff;
      border: none;
      color: #1f2937;
      outline: none;
  }

  .form-input:focus {
      box-shadow: 0 0 0 2px #66bcc9;
  }

  .btn-submit {
      width: 100%;
      color: #ffffff;
      font-family: 'Avenir Black', sans-serif;
      text-transform: uppercase;
      padding: 1.25rem;
      border-radius: 0.75rem;
      font-size: 1.25rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #712c91;
      border: none;
      cursor: pointer;
      transition: all 0.3s ease;
  }

  .btn-submit:hover:not(:disabled) {
      background-color: #5a2374;
      transform: translateY(-2px);
  }

  .location-card {
      position: relative;
      display: flex;
      flex-direction: column;
      background-color: #ffffff;
      border-radius: 2rem;
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }

  @media (min-width: 768px) {
      .location-card {
          display: block;
          height: 450px;
          border-radius: 3rem;
      }
  }

  .map-container {
      width: 100%;
      height: 250px;
      overflow: hidden;
      border-radius: 2rem;
  }

  @media (min-width: 768px) {
      .map-container {
          height: 100%;
          border-radius: 3rem;
      }
  }

  .contact-info-block {
    width: 100%;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-color: rgba(113, 44, 145, 0.98);
    position: relative;
    z-index: 30;
  }

  @media (min-width: 768px) {
    .contact-info-block {
      position: absolute; 
      top: 50%; 
      left: 0; 
      transform: translate(-5rem, -50%); 
      border-radius: 9999px;
      width: 320px; 
      height: 320px;
      background-color: rgba(113, 44, 145, 0.95);
      backdrop-filter: blur(8px);
    }
  }

  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0;
  }
</style>