---
import Layout from "../layouts/Layout.astro";

const seoTitle = "Nosotros | Diseñarte México";
const seoDescription = "Más de 20 años optimizando la comunicación visual del sector industrial con estrategias integrales de diseño, impresión y marketing.";
---

<Layout title={seoTitle} description={seoDescription}>
    <main class="bg-white min-h-screen font-avenir-book overflow-x-hidden">
        
        {/* --- SECCIÓN 1: HERO / SOBRE NOSOTROS --- */}
        <section class="max-w-7xl mx-auto px-6 py-24 overflow-visible" aria-labelledby="hero-heading">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
                
                <div class="flex flex-col space-y-12 z-10">
                    <header class="brand-phrase" aria-label="Más de 20 años de experiencia">
                        <div class="flex items-start">
                            <span class="quote-mark font-avenir-black" aria-hidden="true">“</span>
                            <div class="flex flex-col">
                                <div class="flex items-baseline leading-none text-[#7C07A6] font-avenir-black">
                                    <span class="plus-symbol">+</span>
                                    <h1 id="hero-heading" class="number-hero">20</h1>
                                    <span class="unit-text">años</span>
                                </div>
                                <div class="flex items-center phrase-row whitespace-nowrap">
                                    <span class="support-text">nos respaldan</span>
                                    <span class="quote-mark font-avenir-black second-quote ml-2" aria-hidden="true">”</span>
                                </div>
                            </div>
                        </div>
                    </header>

                    <div class="space-y-8 content-text">
                        <p class="text-xl md:text-2xl leading-relaxed text-[#1a1a1a]">
                            Nos enfocamos en optimizar la comunicación visual 
                            de las empresas, desarrollando <strong class="font-avenir-black text-[#7C07A6]">materiales gráficos</strong> y 
                            <strong class="font-avenir-black text-[#7C07A6]">estrategias digitales</strong> que refuercen su identidad y 
                            presencia en el mercado.
                        </p>
                        <p class="text-xl md:text-2xl leading-relaxed text-[#1a1a1a]">
                            Nuestro equipo de expertos integra diseño gráfico de 
                            alta precisión, impresión especializada, marketing 
                            digital y soluciones publicitarias innovadoras que 
                            fortalecen la presencia y competitividad de las marcas 
                            en el sector industrial.
                        </p>
                    </div>
                </div>

                <div class="relative flex justify-center py-12 lg:py-0">
                    <div class="absolute w-[60%] md:w-[50%] z-0 shadow-sm rounded-sm bg-[#7C07A6] top-0 h-full lg:-top-[25%] lg:h-[135%]"></div>
                    <div class="relative w-full max-w-[500px] aspect-[4/5] z-10">
                        <div class="absolute top-0 left-0 w-[75%] h-[60%] shadow-2xl overflow-hidden border-4 border-white bg-gray-200">
                            <img src="/images/nosotros-1.jpg" alt="Oficina" class="w-full h-full object-cover" />
                        </div>
                        <div class="absolute top-[30%] right-0 w-[65%] h-[45%] shadow-2xl z-20 border-8 border-white bg-gray-300">
                            <img src="/images/nosotros-2.jpg" alt="Impresión" class="w-full h-full object-cover" />
                        </div>
                        <div class="absolute bottom-0 left-[5%] w-[55%] h-[40%] shadow-2xl z-30 border-4 border-white bg-gray-400">
                            <img src="/images/nosotros-3.jpg" alt="Soluciones" class="w-full h-full object-cover" />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* --- SECCIÓN 2: SOLUCIONES --- */}
        <section class="w-full bg-gray-50/50 py-32 px-6 overflow-visible border-y border-gray-100">
            <div class="max-w-7xl mx-auto">
                
                <div class="mb-20 text-left max-w-4xl section-intro">
                    <h2 class="text-xl md:text-2xl font-avenir-book text-gray-900 leading-relaxed">
                        En <span class="font-avenir-black text-[#7C07A6]">Diseñarte México</span>, ofrecemos soluciones integrales 
                        en comunicación visual y marketing digital, adaptadas 
                        a las necesidades del sector industrial y comercial.
                    </h2>
                    <div class="h-1 w-20 bg-[#7C07A6] mt-8 line-decoration"></div>
                </div>

                <div class="flex flex-col lg:flex-row items-center justify-center lg:-space-x-12 space-y-24 lg:space-y-0 overflow-visible mb-24">
                    
                    {/* Flecha 1 */}
                    <div class="arrow-wrapper" style="z-index: 4;">
                        <div class="icon-orb"><img src="/images/icon-pen.png" alt="Diseño" /></div>
                        <div class="arrow-body arrow-grad-1">
                            <div class="content-box">
                                <h3 class="title font-avenir-black text-white uppercase">DISEÑO GRÁFICO</h3>
                                <ul class="font-avenir-book list-disc pl-5 text-white">
                                    <li>Identidad corporativa</li>
                                    <li>Branding</li>
                                    <li>Material publicitario</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    {/* Flecha 2 */}
                    <div class="arrow-wrapper" style="z-index: 3;">
                        <div class="icon-orb"><img src="/images/icon-print.png" alt="Impresión" /></div>
                        <div class="arrow-body arrow-grad-2">
                            <div class="content-box">
                                <h3 class="title font-avenir-black text-white uppercase">IMPRESIÓN PERSONALIZADA</h3>
                                <ul class="font-avenir-book list-disc pl-5 text-white">
                                    <li>Lonas</li>
                                    <li>Viniles</li>
                                    <li>Etiquetas</li>
                                    <li>Señaletica industrial</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    {/* Flecha 3 */}
                    <div class="arrow-wrapper" style="z-index: 2;">
                        <div class="icon-orb"><img src="/images/icon-mkt.png" alt="Marketing" /></div>
                        <div class="arrow-body arrow-grad-3">
                            <div class="content-box">
                                <h3 class="title font-avenir-black text-white uppercase">PUBLICIDAD Y MARKETING DIGITAL</h3>
                                <ul class="font-avenir-book list-disc pl-5 text-white">
                                    <li>Estrategia</li>
                                    <li>Gestión de redes sociales</li>
                                    <li>Campañas publicitarias</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    {/* Flecha 4 */}
                    <div class="arrow-wrapper" style="z-index: 1;">
                        <div class="icon-orb"><img src="/images/icon-light.png" alt="Comunicación" /></div>
                        <div class="arrow-body arrow-grad-4">
                            <div class="content-box">
                                <h3 class="title font-avenir-black text-white uppercase">SOLUCIONES EN COMUNICACIÓN VISUAL</h3>
                                <ul class="font-avenir-book list-disc pl-5 text-white">
                                    <li>Material POP</li>
                                    <li>Stands</li>
                                    <li>Rotulaciones</li>
                                    <li>Exhibidores</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="flex justify-center mt-20">
                    <a href="/publicidad" class="btn-custom-home">
                        <div class="plus-side"><span>+</span></div>
                        <div class="text-side font-avenir-black uppercase">Conoce más</div>
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    @font-face {
        font-family: 'Avenir Book';
        src: url('/fonts/avenir-lt-std-45-book.otf') format('opentype');
        font-weight: normal; font-style: normal; font-display: swap;
    }

    .font-avenir-book { font-family: 'Avenir Book', sans-serif; }
    .font-avenir-black { font-family: 'Avenir LT Std 65 Medium', sans-serif; font-weight: 900; }

    /* HERO STYLES */
    .quote-mark { font-size: 7rem; font-weight: 900; color: #1a1a1a; line-height: 1; }
    .plus-symbol { font-size: 8rem; font-weight: 900; }
    .number-hero { font-size: 12rem; font-weight: 900; letter-spacing: -0.05em; line-height: 0.85; }
    .unit-text { font-size: 6rem; font-weight: 900; margin-left: 0.1em; }
    
    .support-text { 
        font-family: 'Avenir Book', sans-serif; 
        font-size: 5.2rem; 
        color: #1a1a1a; 
        letter-spacing: -2px; 
        line-height: 0.9;
    }

    /* ARROW SYSTEM */
    .arrow-wrapper { position: relative; width: 100%; max-width: 380px; filter: drop-shadow(0 10px 15px rgba(0,0,0,0.1)); }
    .arrow-body {
        position: relative; width: 100%; min-height: 260px; display: flex; align-items: center;
        padding: 2.5rem 2.5rem 2.5rem 3.5rem;
        clip-path: polygon(0% 0%, 82% 0%, 98% 45%, 100% 50%, 98% 55%, 82% 100%, 0% 100%);
    }

    .arrow-grad-1 { background: linear-gradient(135deg, #7C07A6 0%, #5e057e 100%); }
    .arrow-grad-2 { background: linear-gradient(135deg, #8e1bbd 0%, #7C07A6 100%); }
    .arrow-grad-3 { background: linear-gradient(135deg, #a132d2 0%, #8e1bbd 100%); }
    .arrow-grad-4 { background: linear-gradient(135deg, #b449e7 0%, #a132d2 100%); }

    .icon-orb {
        position: absolute; top: -45px; left: 40px; width: 90px; height: 90px;
        background: white; border-radius: 50%; display: flex; justify-content: center; align-items: center;
        z-index: 50; border: 4px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .icon-orb img { width: 50%; height: 50%; object-fit: contain; }
    .content-box { color: white; text-align: left; }
    .title { font-size: 1.1rem; margin-bottom: 0.8rem; line-height: 1.2; }
    ul { font-size: 0.95rem; line-height: 1.5; }

    /* BUTTON */
    .btn-custom-home {
        display: inline-flex; align-items: center;
        background-color: #f4f4f6; border-radius: 100px;
        text-decoration: none; overflow: hidden;
    }
    .plus-side { background-color: #7C07A6; color: white; width: 60px; height: 60px; display: flex; justify-content: center; align-items: center; font-size: 1.8rem; }
    .text-side { color: #1e293b; font-size: 0.9rem; padding: 0 40px 0 25px; letter-spacing: 1px; }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
        .number-hero { font-size: 7rem; }
        .plus-symbol { font-size: 4rem; }
        .unit-text { font-size: 3.5rem; }
        .support-text { font-size: 3.5rem; letter-spacing: -1px; }
        .quote-mark { font-size: 4rem; }
        .arrow-body { clip-path: none; border-radius: 20px; padding-top: 4.5rem; min-height: auto; }
        .icon-orb { left: 50%; transform: translateX(-50%); }
        .section-intro { text-align: center; }
        .line-decoration { margin-left: auto; margin-right: auto; }
    }
</style>