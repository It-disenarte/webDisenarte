---
/**
 * DISEÑARTE MÉXICO - PÁGINA DE MARKETING DIGITAL (FONDO EXTENDIDO)
 * --------------------------------------------------
 * Afinaciones:
 * 1. Fondo (collageBg) extendido hasta el final de la sección (contacto con footer).
 * 2. Posición de fotos superpuestas mantenida en la zona inferior derecha.
 */
import Layout from "../layouts/Layout.astro";

const seoTitle = "Marketing Digital Estratégico | Diseñarte México";
const seoDescription = "Desarrollamos sistemas de adquisición de clientes y estrategias personalizadas.";

const images = {
  heroDetail: "/images/assets/marketing.webp",
  logoCohete: "/images/assets/ICON (1).webp",
  collageBg: "/images/assets/IMGF (1).webp",
  collagePic1: "/images/IMG_1.webp",
  collagePic2: "/images/FOTO_3.webp",
};

const servicios = [
  { texto: "Creación de contenido" },
  { texto: "Sesión de fotos para contenido" },
  { texto: "Campañas publicitarias" },
  { texto: "Optimización de resultados" },
  { texto: "Optimización Google maps" },
];
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="pt-32 pb-0 bg-white selection:bg-[#7C07A6] selection:text-white overflow-x-hidden font-avenir-book">
    
    <section class="px-4 mb-24 lg:mb-32">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
          <div class="order-2 lg:order-1 relative group overflow-hidden">
            <img 
              src={images.heroDetail} 
              alt="Estrategia MKT" 
              class="w-full h-full object-contain transition-transform duration-700 group-hover:scale-105" 
            />
          </div>

          <article class="flex flex-col items-center lg:items-start text-center lg:text-left space-y-8 order-1 lg:order-2">
            <header class="flex flex-col md:flex-row items-center gap-6">
              <img src={images.logoCohete} alt="Cohete" class="h-16 md:h-20 w-auto animate-float-slow" />
              <h1 class="text-4xl md:text-6xl font-avenir-black uppercase tracking-tighter leading-none" style="color: #7C07A6;">
                Marketing <span class="text-black">Digital</span>
              </h1>
            </header>
            <div class="space-y-6 max-w-xl">
              <p class="text-lg md:text-xl font-avenir-book text-gray-800 leading-relaxed">
                Desarrollamos un sistema de adquisición de clientes que permite analizar de forma estratégica las necesidades de su empresa, evaluar el estado actual de sus redes sociales y definir proyecciones de crecimiento.
              </p>
              <div class="h-1.5 w-24 bg-[#7C07A6] mx-auto lg:mx-0 rounded-full opacity-60"></div>
              <p class="text-lg md:text-xl font-avenir-book text-gray-800 leading-relaxed">
                Con base en este diagnóstico, seleccionamos los canales digitales más adecuados y diseñamos una estrategia personalizada, orientada a resultados y objetivos comerciales.
              </p>
              <div class="pt-6">
                <p class="text-2xl md:text-3xl font-avenir-book leading-tight tracking-tight" style="color: #7C07A6;">
                  “Estrategias digitales diseñadas... <b class="font-avenir-black ml-1">para resultados tangibles.</b>”
                </p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="pt-24 pb-0 px-4 bg-white border-t border-gray-50 overflow-hidden flex flex-col">
      <div class="max-w-7xl mx-auto w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-32 items-stretch">
          
          <div class="flex flex-col items-center lg:items-start space-y-12 pb-24">
            <div class="w-full">
              <h2 class="text-xl font-avenir-book uppercase tracking-[0.2em] mb-8 text-center lg:text-left" style="color: #7C07A6;">
                Conoce nuestros servicios:
              </h2>
              <ul class="space-y-5">
                {servicios.map((s) => (
                  <li class="flex items-center space-x-4 text-lg md:text-xl text-gray-700 font-avenir-book group">
                    <span class="text-2xl group-hover:scale-125 transition-transform" style="color: #7C07A6;">✓</span>
                    <span>{s.texto}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="w-full flex justify-center lg:justify-start">
              <a href="/contacto" class="bg-[#7C07A6] hover:bg-[#5a2484] text-white px-10 py-3 rounded-full text-sm font-avenir-black shadow-lg uppercase tracking-widest transition-all duration-300 hover:scale-105 active:scale-95">
                Contáctanos
              </a>
            </div>

            <div class="pt-8 w-full select-none">
              <h2 class="text-6xl md:text-[7.5rem] font-avenir-black tracking-tighter leading-[0.75] uppercase text-center lg:text-left">
                <span class="block" style="color: #7C07A6;">“Haz que</span>
                <span class="text-[#facc15] flex items-center justify-center lg:justify-start">
                  <span class="text-7xl md:text-[9.5rem] mr-2">+</span>gente
                </span>
                <span class="block" style="color: #7C07A6;">te vea”</span>
              </h2>
            </div>
          </div>

          <aside class="relative w-full flex items-stretch lg:justify-end min-h-[700px]">
            <div class="relative w-full max-w-[500px] md:max-w-[600px]">
              
              <div class="absolute -left-10 top-0 w-[100%] h-full overflow-hidden z-0 bg-gray-100 shadow-sm">
                <img src={images.collageBg} alt="MKT Background Texture" class="w-full h-full object-cover grayscale-[0.2]" />
              </div>
              
              <div class="absolute top-[10%] right-0 w-[55%] aspect-square bg-gray-200 z-10 rotate-[5deg] overflow-hidden transition-transform duration-500 hover:rotate-0 shadow-xl">
                <img src={images.collagePic1} alt="Marketing Pic 1" class="w-full h-full object-cover" />
              </div>
              
              <div class="absolute bottom-[10%] left-[20%] w-[75%] aspect-square bg-gray-200 z-20 rotate-[-4deg] overflow-hidden transition-transform duration-500 hover:rotate-0 shadow-xl">
                <img src={images.collagePic2} alt="Marketing Pic 2" class="w-full h-full object-cover" />
              </div>
            </div>
          </aside>

        </div>
      </div>
    </section>

  </main>
</Layout>

<style is:global>
  @font-face {
    font-family: 'Avenir Book';
    src: url('/fonts/avenir-lt-std-45-book.otf') format('opentype');
    font-weight: 400; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: 'Avenir Black';
    src: url('/fonts/avenir-lt-std-65-medium.otf') format('opentype');
    font-weight: 900; font-style: normal; font-display: swap;
  }

  .font-avenir-book { font-family: 'Avenir Book', sans-serif; }
  .font-avenir-black { font-family: 'Avenir Black', sans-serif; font-weight: 900; }
  
  @keyframes floatSlow {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(-15px) rotate(3deg); }
  }
  .animate-float-slow { animation: floatSlow 6s ease-in-out infinite; }
</style>