---
/**
 * DISEÑARTE MÉXICO - PÁGINA DE PUBLICIDAD (VERSION SIN MARCOS)
 */
import Layout from "../layouts/Layout.astro";

const seoTitle = "Publicidad y Comunicación Visual | Diseñarte México";
const seoDescription = "Soluciones integrales en publicidad, diseño gráfico, señalética y material POP.";

const slides = [
  {
    titulo: "Diseño gráfico",
    puntos: ["Creación de logotipos", "Manual de identidad", "Identidad corporativa", "Branding", "Imagen corporativa integral"],
    imagen: "src/assets/DISENO GRAFICO.png"
  },
  {
    titulo: "Señalética",
    puntos: ["Letreros", "Etiquetas", "Rotulación de tuberías", "Delimitación de áreas", "Código de colores", "Rotulación de tanques/silos", "Campañas de seguridad e higiene"],
    imagen: "src/assets/SENALETICA.webp"
  },
  {
    titulo: "Impresión digital",
    puntos: ["Lona 13oz", "Wall Graphic", "Fotomural", "Vinil brillante/mate", "Vinil wrap", "Microperforado", "Floor graphic"],
    imagen: "src/assets/IMPRESION-DIGITAL.webp"
  },
  {
    titulo: "Tableros",
    puntos: ["Móvil", "Giratorio", "Cruz de seguridad", "Con acrílico", "Imantado", "Personalizado", "Dinámicos de EHS/KPI´S"],
    imagen: "src/assets/TABLEROS.webp"
  },
  {
    titulo: "Corte y grabado láser",
    puntos: ["Acrílico", "MDF", "Papel", "Madera", "ABS", "Led"],
    imagen: "src/assets/CORTE Y GRADO LASER.webp"
  },
  {
    titulo: "Acrílico",
    puntos: ["Gravoply", "Termos", "Cristal", "Cuero", "Corpóreo 3D", "Porta hojas", "Proyectos especiales"],
    imagen: "src/assets/ACRILICO.webp"
  },
  {
    titulo: "Rotulación",
    puntos: ["Corte de vinil", "Cuadrillas completas", "Balizado", "Diseño personalizado"],
    imagen: "src/assets/ROTULACION.webp"
  }
];

const transformacion = [
  { id: "01", etiqueta: "Espacio a trabajar", negrita: "Espacio", imagen: "/images/antes.webp" },
  { id: "02", etiqueta: "Diseño y desarrollo", negrita: "Diseño", imagen: "/images/diseno.webp" },
  { id: "03", etiqueta: "instalación final", negrita: "instalación", imagen: "/images/final.webp" }
];

const popItems = ["Volantes", "Tarjetas", "Formatos", "Calendarios", "Etiquetas", "Folletos", "Marbetes", "Sellos", "Banner", "Libretas", "Tazas", "Playeras", "Agendas", "Termos", "Etc..."];
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="bg-[#f9f9f9] selection:bg-[#7C07A6] selection:text-white overflow-x-hidden font-avenir-book">
    
    <section class="pt-24 md:pt-32 pb-20 max-w-7xl mx-auto px-4">
      <header class="mb-16 md:mb-24 flex flex-col items-center text-center">
        <div class="max-w-4xl">
          <h1 class="text-2xl md:text-5xl font-avenir-book leading-tight text-gray-800 tracking-tight">
            <span class="font-avenir-black text-black mr-2 md:mr-3 inline-block">“</span>
            <b class="font-avenir-black" style="color: #7C07A6;">Publicidad</b> con propósito: 
            <b class="font-avenir-black ml-1" style="color: #7C07A6;">creamos</b> atmósferas que comunican, 
            inspiran y <b class="font-avenir-black ml-1" style="color: #7C07A6;">transforman</b> espacios.
            <span class="font-avenir-black text-black ml-1">”</span>
          </h1>
          <div class="h-1.5 w-20 bg-[#7C07A6] mx-auto mt-8 md:mt-10 rounded-full"></div>
        </div>
      </header>

      <div class="relative grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center min-h-[550px]">
        <div class="lg:col-span-7 h-[350px] md:h-[500px] lg:h-[600px] relative overflow-hidden group">
          {slides.map((slide, index) => (
            <div class={`absolute inset-0 transition-all duration-700 ease-in-out transform ${index === 0 ? 'opacity-100 scale-100 z-10' : 'opacity-0 scale-95 z-0'}`} data-slide-img={index}>
              <img src={slide.imagen} alt={slide.titulo} class="w-full h-full object-contain" />
            </div>
          ))}
          <nav class="absolute inset-0 z-30 pointer-events-none flex items-center justify-between px-0">
            <button id="prev-btn" class="pointer-events-auto p-3 md:p-4 rounded-full bg-black/10 backdrop-blur-sm text-white hover:bg-[#7C07A6] transition-all" aria-label="Anterior">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            </button>
            <button id="next-btn" class="pointer-events-auto p-3 md:p-4 rounded-full bg-black/10 backdrop-blur-sm text-white hover:bg-[#7C07A6] transition-all" aria-label="Siguiente">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 md:h-8 md:w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
          </nav>
        </div>

        <article class="lg:col-span-5 relative min-h-[400px] flex items-center">
          {slides.map((slide, index) => (
            <div class={`absolute inset-0 transition-all duration-500 flex flex-col justify-center ${index === 0 ? 'visible-slide' : 'hidden-slide'}`} data-slide-text={index}>
              <h2 class="text-3xl md:text-4xl font-avenir-black uppercase tracking-tighter mb-6 leading-none" style="color: #7C07A6;">{slide.titulo}</h2>
              <ul class="space-y-1.5 md:space-y-2">
                {slide.puntos.map((punto) => (
                  <li class="flex items-start space-x-3 text-base md:text-[17px] text-gray-600 font-avenir-book leading-tight">
                    <span class="font-avenir-black text-lg leading-none" style="color: #7C07A6;">/</span><span>{punto}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </article>
      </div>
    </section>

    <section class="bg-white py-20 md:py-32 border-t border-gray-100 overflow-hidden">
      <div class="max-w-[1600px] mx-auto px-4 md:px-10">
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-10 md:gap-20 items-stretch">
          
          <div class="flex flex-col">
            <header class="mb-10">
              <h2 class="text-3xl md:text-5xl font-avenir-black tracking-tighter uppercase leading-none" style="color: #7C07A6;">
                “Imagen <span class="font-avenir-book text-black">corporativa</span>”
              </h2>
            </header>
            <div class="flex-1 flex flex-col rounded-3xl overflow-hidden shadow-2xl bg-[#fcfcfc] border border-gray-100 min-h-[500px]">
              <div class="p-8 md:p-12 bg-white relative min-h-[250px] flex flex-col justify-center border-b border-gray-50">
                <div class="relative h-24 flex items-center">
                  {transformacion.map((item, i) => (
                    <div id={`text-trans-${item.id}`} class={`absolute inset-x-0 transition-all duration-500 transform ${i === 0 ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-4 pointer-events-none'}`}>
                      <h3 class="text-2xl md:text-4xl font-avenir-black uppercase leading-none tracking-tighter" style="color: #7C07A6;">
                        “{item.negrita} <span class="font-avenir-book text-black">{item.etiqueta.replace(item.negrita, '')}</span>”
                      </h3>
                    </div>
                  ))}
                </div>
                <div class="flex gap-6 mt-8">
                  {transformacion.map((item, i) => (
                    <button data-target-trans={item.id} class={`group flex flex-col gap-3 transition-all duration-300 cursor-pointer ${i === 0 ? 'opacity-100' : 'opacity-30 hover:opacity-100'}`}>
                      <span class="text-2xl font-avenir-black" style="color: #7C07A6;">{item.id}</span>
                      <div class="h-1.5 w-12 bg-gray-100 rounded-full overflow-hidden">
                        <div id={`bar-trans-${item.id}`} class={`h-full transition-all duration-500 ${i === 0 ? 'w-full' : 'w-0'}`} style="background-color: #7C07A6;"></div>
                      </div>
                    </button>
                  ))}
                </div>
              </div>
              <div class="flex-1 relative bg-black overflow-hidden min-h-[300px]">
                {transformacion.map((item, i) => (
                  <div id={`img-trans-${item.id}`} class={`absolute inset-0 transition-all duration-1000 transform scale-110 ${i === 0 ? 'opacity-100 scale-100 z-10' : 'opacity-0 z-0'}`}>
                    <img src={item.imagen} alt={item.etiqueta} class="w-full h-full object-cover" />
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="flex flex-col">
            <header class="mb-10">
              <h2 class="text-3xl md:text-5xl font-avenir-black tracking-tighter uppercase leading-none" style="color: #7C07A6;">
                “Material <span class="font-avenir-book text-black">POP</span>”
              </h2>
            </header>
            <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-8 items-center bg-[#f9f9f9] rounded-3xl p-8 md:p-12 border border-gray-100 shadow-sm overflow-hidden">
              <div class="grid grid-cols-2 gap-y-4 gap-x-2">
                {popItems.map((item) => (
                 <div class="flex items-center space-x-2 group">
                    <span class="font-avenir-black opacity-30 group-hover:opacity-100 transition-opacity" style="color: #7C07A6;">/</span>
                    <span class="text-sm md:text-base font-avenir-book text-gray-600 group-hover:text-black transition-colors">{item}</span>
                  </div>
                ))}
              </div>
              <div class="relative h-[300px] md:h-[400px] flex items-center justify-center">
                <div class="absolute w-[110%] h-[110%] -left-10 top-0 overflow-hidden transform -rotate-6 z-10 scale-110">
                  <img src="src/assets/MATERIAL POP1.webp" alt="material POP1" class="w-full h-full object-contain opacity-100" />
                </div>
                <div class="absolute w-[75%] h-[75%] -right-10 -bottom-10 overflow-hidden transform rotate-6 z-20">
                  <img src="src/assets/MATERIAL POP2.webp" alt="material POP2" class="w-full h-full object-contain" />
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  @font-face {
    font-family: 'Avenir Book';
    src: url('/fonts/avenir-lt-std-45-book.otf') format('opentype');
    font-weight: 400; font-style: normal; font-display: swap;
  }
  @font-face {
    font-family: 'Avenir Black';
    src: url('/fonts/avenir-lt-std-65-medium.otf') format('opentype');
    font-weight: 900; font-style: normal; font-display: swap;
  }

  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  .font-avenir-book { font-family: 'Avenir Book', sans-serif; }
  .font-avenir-black { font-family: 'Avenir Black', sans-serif; font-weight: 900; }
  
  .visible-slide { opacity: 1 !important; transform: translateX(0) !important; z-index: 10; pointer-events: auto; }
  .hidden-slide { opacity: 0 !important; transform: translateX(20px) !important; z-index: 0; pointer-events: none; }
</style>

<script>
  function initPublicidad() {
    let currentSlide = 0;
    const slideImgs = document.querySelectorAll('[data-slide-img]');
    const slideTexts = document.querySelectorAll('[data-slide-text]');
    const total = slideImgs.length;

    if (total > 0) {
      const updateCarousel = (idx: number) => {
        slideImgs.forEach((img, i) => {
          img.classList.toggle('opacity-100', i === idx);
          img.classList.toggle('scale-100', i === idx);
          img.classList.toggle('z-10', i === idx);
          img.classList.toggle('opacity-0', i !== idx);
          img.classList.toggle('scale-95', i !== idx);
        });
        slideTexts.forEach((text, i) => {
          if (i === idx) {
            text.classList.replace('hidden-slide', 'visible-slide');
          } else {
            text.classList.replace('visible-slide', 'hidden-slide');
          }
        });
      };

      document.getElementById('next-btn')?.addEventListener('click', () => { 
        currentSlide = (currentSlide + 1) % total; 
        updateCarousel(currentSlide); 
      });
      document.getElementById('prev-btn')?.addEventListener('click', () => { 
        currentSlide = (currentSlide - 1 + total) % total; 
        updateCarousel(currentSlide); 
      });
    }

    const transButtons = document.querySelectorAll('[data-target-trans]');
    const transTexts = document.querySelectorAll('[id^="text-trans-"]');
    const transImgs = document.querySelectorAll('[id^="img-trans-"]');
    const transBars = document.querySelectorAll('[id^="bar-trans-"]');

    transButtons.forEach(btn => {
      btn.addEventListener('mouseenter', () => {
        const id = btn.getAttribute('data-target-trans');
        transButtons.forEach(b => (b as HTMLElement).style.opacity = b === btn ? '1' : '0.3');
        transBars.forEach(bar => (bar as HTMLElement).style.width = bar.id === `bar-trans-${id}` ? '100%' : '0');
        transTexts.forEach(t => {
          const active = t.id === `text-trans-${id}`;
          t.classList.toggle('opacity-100', active);
          t.classList.toggle('translate-y-0', active);
          t.classList.toggle('opacity-0', !active);
          t.classList.toggle('translate-y-4', !active);
        });
        transImgs.forEach(img => {
          const active = img.id === `img-trans-${id}`;
          img.classList.toggle('opacity-100', active);
          img.classList.toggle('scale-100', active);
          img.classList.toggle('z-10', active);
          img.classList.toggle('opacity-0', !active);
          img.classList.toggle('scale-110', !active);
        });
      });
    });
  }

  initPublicidad();
  document.addEventListener('astro:page-load', initPublicidad);
</script>