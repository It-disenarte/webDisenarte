---
/**
 * src/components/WhatsAppFloater.astro
 * SOLUCIÓN DEFINITIVA: Separación de elementos para liberar espacio de clics.
 */
---

<div 
  id="wa-card" 
  class="fixed bottom-24 right-6 z-[100] w-72 bg-white rounded-2xl shadow-2xl overflow-hidden opacity-0 translate-y-4 pointer-events-none transition-all duration-300 ease-out border border-gray-100 hidden"
  transition:persist="whatsapp-card"
>
  <div class="bg-[#5a2484] p-4 flex items-center space-x-3">
    <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center">
      <img src="/images/LOGO.webp" alt="Logo" class="w-6 h-6 object-contain" />
    </div>
    <div>
      <p class="text-white text-sm font-bold leading-tight">Diseñarte México</p>
      <p class="text-purple-200 text-[10px]">En línea ahora</p>
    </div>
  </div>

  <div class="p-4 bg-[#e5ddd5] min-h-[100px] flex flex-col space-y-3">
    <div class="bg-white p-3 rounded-lg rounded-tl-none shadow-sm max-w-[90%] self-start border-l-4 border-[#25D366]">
      <p class="text-[13px] text-gray-800 leading-snug font-medium">
        ¿Podemos llevarte al siguiente nivel?
      </p>
      <span class="text-[9px] text-gray-400 block text-right mt-1 uppercase tracking-wider">Recibido</span>
    </div>
  </div>

  <div class="p-3 bg-white flex items-center space-x-2 border-t border-gray-100">
    <div class="flex-1 bg-gray-50 px-4 py-2 rounded-full border border-gray-200">
      <p class="text-xs text-gray-500 font-semibold italic">Sí, por favor...</p>
    </div>
    <button 
      id="send-wa-btn" 
      class="bg-[#25D366] hover:bg-[#128C7E] w-10 h-10 rounded-full flex items-center justify-center transition-all shadow-md pointer-events-auto active:scale-90"
    >
      <svg viewBox="0 0 24 24" class="w-5 h-5 fill-white ml-1"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"></path></svg>
    </button>
  </div>
</div>

<button 
  id="wa-trigger" 
  class="fixed bottom-6 right-6 z-[101] w-16 h-16 bg-[#25D366] hover:bg-[#128C7E] rounded-full flex items-center justify-center shadow-xl transition-all duration-300 active:scale-95 pointer-events-auto"
  transition:persist="whatsapp-btn"
  aria-label="Abrir chat de WhatsApp"
>
  <img src="/images/assets/WhatsApp.svg.webp" alt="WhatsApp" class="w-9 h-9" />
  <span class="absolute top-1 right-1 flex h-4 w-4">
    <span class="relative inline-flex rounded-full h-4 w-4 bg-red-600 border-2 border-white animate-pulse"></span>
  </span>
</button>

<script is:inline>
  function setupWhatsApp() {
    const trigger = document.getElementById('wa-trigger');
    const card = document.getElementById('wa-card');
    const sendBtn = document.getElementById('send-wa-btn');

    if (!trigger || !card) return;

    // Aseguramos estado inicial limpio
    if (!card.classList.contains('opacity-100')) {
        card.classList.add('hidden');
    }

    trigger.onclick = (e) => {
      e.stopPropagation();
      const isHidden = card.classList.contains('hidden');
      
      if (isHidden) {
        // Mostramos la tarjeta
        card.classList.remove('hidden');
        // Pequeño delay para que la transición de CSS se note
        setTimeout(() => {
          card.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
          card.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        }, 10);
      } else {
        closeWhatsApp();
      }
    };

    function closeWhatsApp() {
      card.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
      card.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
      // Esperamos a que termine la animación de 300ms para ocultarlo del DOM
      setTimeout(() => {
        if (card.classList.contains('opacity-0')) {
          card.classList.add('hidden');
        }
      }, 300);
    }

    sendBtn.onclick = () => {
      const phone = "+524271004183"; 
      const message = encodeURIComponent("Sí, por favor. Me gustaría llevar mi negocio al siguiente nivel.");
      window.open(`https://wa.me/${phone}?text=${message}`, '_blank');
    };

    // Cerrar al hacer clic en cualquier parte de la pantalla
    document.addEventListener('click', (ev) => {
      if (!card.contains(ev.target) && !trigger.contains(ev.target)) {
        closeWhatsApp();
      }
    });
  }

  // Ejecución inicial y en cambios de página de Astro
  setupWhatsApp();
  document.addEventListener('astro:page-load', setupWhatsApp);
</script>

<style>
  #wa-trigger { 
    box-shadow: 0 8px 24px -4px rgba(37, 211, 102, 0.5); 
    -webkit-tap-highlight-color: transparent; /* Elimina el recuadro gris al tocar en móviles */
  }
  
  /* Animación suave para la tarjeta */
  #wa-card {
    will-change: opacity, transform;
  }
</style>